{
	"name": "df_bronze_cargar_datos",
	"properties": {
		"folder": {
			"name": "Bronze"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_datos_entel_csv",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_sql_datos_entel",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [],
			"scriptLines": [
				"source(output(",
				"          FECHA_INICIO as string,",
				"          FECHA_FIN as string,",
				"          NUMERO as string,",
				"          IMEI as string,",
				"          RBS_UTILIZADA as string,",
				"          CELDA as string,",
				"          LATITUD_LONGITUD_CELDA as string,",
				"          {VOLUMEN_DATOS_SUBIDOS(BYTES)} as string,",
				"          {VOLUMEN_DATOS_DESCARGADOS(BYTES)} as string,",
				"          {VOLUMEN_TOTAL_DATOS(BYTES)} as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          fecha_inicio as string,",
				"          fecha_fin as string,",
				"          numero as string,",
				"          imei as string,",
				"          rbs_utilizada as string,",
				"          celda as string,",
				"          latitud_longitud as string,",
				"          subidos as string,",
				"          descargados as string,",
				"          total as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          fecha_inicio = FECHA_INICIO,",
				"          fecha_fin = FECHA_FIN,",
				"          numero = NUMERO,",
				"          imei = IMEI,",
				"          rbs_utilizada = RBS_UTILIZADA,",
				"          celda = CELDA,",
				"          latitud_longitud = LATITUD_LONGITUD_CELDA,",
				"          subidos = {VOLUMEN_DATOS_SUBIDOS(BYTES)},",
				"          descargados = {VOLUMEN_DATOS_DESCARGADOS(BYTES)},",
				"          total = {VOLUMEN_TOTAL_DATOS(BYTES)}",
				"     )) ~> sink1"
			]
		}
	}
}